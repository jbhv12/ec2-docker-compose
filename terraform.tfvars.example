# Copy to terraform.tfvars and set your values
# Optional: When null, deployer IP is auto-detected. Set when using Terraform Cloud remote execution or to override.

# allowed_cidr = "YOUR_IP/32"   # e.g., "203.0.113.42/32" (optional; auto-detected when not set)

# Optional overrides:
# aws_region         = "us-east-1"
# instance_type      = "t3.micro"
# root_volume_size_gb = 30
# compose_file_path  = "docker-compose.yml"
